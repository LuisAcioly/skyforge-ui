  "primitive": {
    "color": {
      "base": {
        "white": {
          "$type": "color",
          "$value": "#FFFFFF",
          "$description": "Technical white for raised surfaces and foregrounds."
        },
        "black": {
          "$type": "color",
          "$value": "#000000",
          "$description": "Technical black reserved for alpha overlays and non-UI compositing only. Do not use for visible component states."
        }
