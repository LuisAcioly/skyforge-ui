          "$value": "#515656",
          "$description": "Structural brand neutral aligned with neutral 700."
        },
        "soft-linen": {
          "$type": "color",
          "$value": "#E4E0D5",
          "$description": "Warm editorial surface color used sparingly for narrative emphasis."
        },
        "muted-teal": {
