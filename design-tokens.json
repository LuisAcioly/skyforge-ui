          "$type": "color",
          "$value": "#161B1E",
          "$description": "Primary brand authority color used for light theme CTAs and dark theme canvas."
        },
        "shadow-ink": {
          "$type": "color",
          "$value": "#323738",
          "$description": "Dark ink surface color separated from neutral 900 for visible dark-mode surfaces."
        },
        "charcoal": {
