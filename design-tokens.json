      "none": {
        "$type": "shadow",
        "$value": "none",
        "$description": "No elevation."
      },
      "1": {
        "$type": "shadow",
        "$value": "0 1px 2px rgb(22 27 30 / 0.04), 0 8px 24px rgb(22 27 30 / 0.035)",
        "$description": "Subtle elevation for interactive cards and small menus only."
      },
      "2": {
        "$type": "shadow",
        "$value": "0 8px 24px rgb(22 27 30 / 0.08), 0 24px 48px rgb(22 27 30 / 0.06)",
        "$description": "Medium elevation for popovers and floating panels."
      },
      "3": {
        "$type": "shadow",
        "$value": "0 24px 64px rgb(22 27 30 / 0.18), 0 48px 96px rgb(22 27 30 / 0.14)",
        "$description": "High elevation for modals."
      }
    },
